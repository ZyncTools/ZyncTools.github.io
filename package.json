{
  "name": "zyncpdf",
  "version": "2.0.0",
  "description": "ZyncPDF - Professional PDF Workspace. Open-source, privacy-first PDF toolkit for the browser.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.js",
    "format": "prettier --write \"**/*.{ts,js,json,html,css,md}\"",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pdf",
    "pdf-editor",
    "pdf-annotator",
    "pdf-merger",
    "pdf-splitter",
    "pdf-compressor",
    "pdf-text-editor",
    "privacy-first",
    "client-side",
    "offline-first",
    "pwa",
    "open-source"
  ],
  "author": "ZyncPDF Team",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/alanjollyc/ZyncPDF.git"
  },
  "bugs": {
    "url": "https://github.com/alanjollyc/ZyncPDF/issues"
  },
  "homepage": "https://zyncpdf.github.io/",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-legacy": "^5.3.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "terser": "^5.27.0"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.0.0",
    "jszip": "^3.10.1"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "not dead"
  ]
}